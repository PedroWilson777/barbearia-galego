# ============================================
# GALEGO BARBEARIA - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git!

# ----- Banco de Dados (Railway PostgreSQL) -----
# Pegue em: Railway > seu projeto > Postgres > Variables > DATABASE_URL
DATABASE_URL="postgresql://usuario:senha@host.railway.app:5432/railway"

# ----- Anthropic (Sofia / Claude) -----
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX"

# Modelo da Sofia (recomendado: Haiku 4.5)
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# ----- Evolution API (WhatsApp) -----
EVOLUTION_API_URL="https://evolution-evolution-api.eeb1ij.easypanel.host"
EVOLUTION_API_KEY="cole-sua-chave-evolution-aqui"
EVOLUTION_INSTANCE="teste"

# ----- App -----
# URL pública do seu deploy (Railway vai te dar)
NEXT_PUBLIC_APP_URL="https://seu-projeto.up.railway.app"

# Senha do supervisor pra acessar o painel (defina uma senha forte)
SUPERVISOR_PASSWORD="troca-essa-senha-por-uma-forte"
